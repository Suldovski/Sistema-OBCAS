{
  "base_url": "https://webservices.esocial.gov.br",
  "cert": {
    "type": "pfx",
    "pfx_path": "${ESOCIAL_PFX_PATH}",
    "pfx_password": "${ESOCIAL_PFX_PASSWORD}"
  },
  "endpoints": {
    "auth": "/api/v1/auth",
    "aso": "/api/v1/aso/list"
  },
  "request": {
    "verify_ssl": true,
    "auth_method": "POST",
    "aso_method": "GET",
    "auth_payload": {
      "cnpj": "${ESOCIAL_CNPJ}"
    },
    "aso_params": {
      "cnpj": "${ESOCIAL_CNPJ}",
      "limite": 226
    },
    "headers": {
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "mapping": {
    "records_path": "data.asos",
    "date_keys": ["vencimento_aso", "dataVencimento", "vencimento"]
  }
}

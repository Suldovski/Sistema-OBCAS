{
  "base_url": "https://webservices.esocial.gov.br",
  "cert": {
    "type": "pfx",
    "pfx_path": "COLOQUE_AQUI_O_CAMINHO_DO_SEU_CERTIFICADO.pfx",
    "pfx_password": "COLOQUE_AQUI_A_SENHA_DO_CERTIFICADO"
  },
  "endpoints": {
    "auth": "/api/v1/auth",
    "aso": "/api/v1/aso/list"
  },
  "request": {
    "verify_ssl": true,
    "auth_method": "POST",
    "aso_method": "GET",
    "headers": {
      "Accept": "application/json",
      "Content-Type": "application/json"
    }
  },
  "mapping": {
    "records_path": "data.asos",
    "date_keys": ["vencimento_aso", "dataVencimento", "vencimento"]
  }
}
